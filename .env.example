# Nombre del proyecto (usado en docker-compose y nginx)
PROJECT_NAME=miproyecto

# Dominio de producción (usado por deploy.sh y nginx)
DOMAIN=tudominio.com

# Puerto externo de la app
APP_PORT=8000

# Django
SECRET_KEY=cambia-esto-por-una-clave-secreta-segura
DEBUG=False
ALLOWED_HOSTS=tudominio.com,www.tudominio.com
CSRF_TRUSTED_ORIGINS=https://tudominio.com,https://www.tudominio.com
ADMIN_URL=mi-panel-secreto/
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@tudominio.com

# PostgreSQL
POSTGRES_DB=miproyecto_db
POSTGRES_USER=miproyecto_user
POSTGRES_PASSWORD=cambia-esta-contraseña
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu@email.com
EMAIL_HOST_PASSWORD=tu-contraseña-de-app
DEFAULT_FROM_EMAIL=noreply@tudominio.com

# Nextcloud
NEXTCLOUD_SERVER_URL=https://sky.redlinegs.com
# OAuth2: registrar app en Nextcloud > Configuración > Seguridad > Clientes OAuth2
# URI de redirección a configurar: https://tudominio.com/login/callback/
NEXTCLOUD_OAUTH2_CLIENT_ID=
NEXTCLOUD_OAUTH2_CLIENT_SECRET=
# Debe coincidir exactamente con la URI registrada en Nextcloud
NEXTCLOUD_OAUTH2_REDIRECT_URI=https://tudominio.com/login/callback/
# URL a la que se vuelve tras el login (dejar vacío para ir a /dashboard/)
NEXTCLOUD_RETURN_URL=

# Almacenamiento de capturas en Nextcloud (opcional).
# Si se define NEXTCLOUD_SCREENSHOTS_USER, las capturas se suben vía WebDAV
# en lugar de guardarse en MEDIA_ROOT. Requiere una app-password de Nextcloud.
NEXTCLOUD_SCREENSHOTS_USER=skylog-agent
NEXTCLOUD_SCREENSHOTS_PASSWORD=mEWaW-Yp2x3-JiKt7-BQXKB-HRFN3
NEXTCLOUD_SCREENSHOTS_FOLDER=100_Skylog/screenshots

# WebSocket / Redis
# En producción: redis://redis:6379/0
# En desarrollo (vacío = InMemoryChannelLayer, sin Redis):
REDIS_URL=

# n8n (deshabilitado — descomentar para habilitar)
# N8N_ENCRYPTION_KEY=clave-larga-y-secreta
# N8N_DOMAIN=proyecto-n8n.tudominio.com
# N8N_BASE_URL=https://proyecto-n8n.tudominio.com
