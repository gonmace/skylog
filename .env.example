# Nombre del proyecto (usado en docker-compose y nginx)
PROJECT_NAME=miproyecto

# Dominio de producción (usado por deploy.sh y nginx)
DOMAIN=tudominio.com

# Puerto externo de la app
APP_PORT=8000

# Django
SECRET_KEY=cambia-esto-por-una-clave-secreta-segura
DEBUG=False
ALLOWED_HOSTS=tudominio.com,www.tudominio.com
CSRF_TRUSTED_ORIGINS=https://tudominio.com,https://www.tudominio.com
ADMIN_URL=mi-panel-secreto/

# PostgreSQL
POSTGRES_DB=miproyecto_db
POSTGRES_USER=miproyecto_user
POSTGRES_PASSWORD=cambia-esta-contraseña
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432   # Puerto expuesto en el host (dev: acceso desde DBeaver, etc.)

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu@email.com
EMAIL_HOST_PASSWORD=tu-contraseña-de-app
DEFAULT_FROM_EMAIL=noreply@tudominio.com

# n8n (opcional)
# Si N8N_DOMAIN no está definido, n8n no se levanta y nginx no genera su bloque.
# Para habilitar n8n, descomentar y completar las tres variables.
# N8N_ENCRYPTION_KEY debe mantenerse constante — cambiarla invalida las credenciales guardadas.
# N8N_ENCRYPTION_KEY=clave-larga-y-secreta
# N8N_DOMAIN=proyecto-n8n.tudominio.com
# N8N_BASE_URL=https://proyecto-n8n.tudominio.com
